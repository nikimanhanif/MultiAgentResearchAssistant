# FastAPI Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# DeepSeek Config
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# OpenAI Config
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EVAL_MODEL=gpt-5-nano

# LangSmith (Trace Observability)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=multi-agent-research-assistant
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# DeepEval config
DEEPEVAL_TELEMETRY_OPT_OUT=true

# Tavily Web Search API
TAVILY_API_KEY=your_tavily_api_key_here

# CORE Academic Database (via Scientific Paper Harvester MCP)
CORE_API_KEY=your_core_api_key_here

# PostgreSQL URL (async driver: asyncpg)
DATABASE_URL=your_database_url_here

# Semantic Scholar API
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# Scopus API (Elsevier)
SCOPUS_API_KEY=your_scopus_api_key_here
SCOPUS_INST_TOKEN=your_scopus_inst_token_here

# DRB Evaluation (DeepResearch Bench)
DRB_REPO_PATH=your_drp_repo_path_here
DRB_JUDGE_PROVIDER=deepseek
DRB_RACE_MODEL=deepseek-chat
DRB_FACT_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
JINA_API_KEY=your_jina_api_key_here

